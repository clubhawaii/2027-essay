.cpar li b{color:var(--pink)}.cpar .cex{color:var(--sub);font-size:12.5px}
.cpar .cnone{font-size:13px;color:var(--sub);margin:0}.cpar .cwarn{font-size:12.5px;color:var(--sub);margin:7px 0 0}
.month h2{display:flex;justify-content:center;align-items:center;margin:2px 2px 14px;font-size:21px;font-weight:800;line-height:1;}
.month h2 small{color:#888;font-weight:600;margin-left:8px;}
