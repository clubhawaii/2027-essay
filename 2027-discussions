/* ---- 대학명 검색 (하이라이트 + 디밍) ---- */
const qEl=document.getElementById('q'), qcountEl=document.getElementById('qcount');
function runSearch(){
  const q=(qEl.value||'').trim().toLowerCase();
  const searching = q !== "";
  const hits=new Set();

  document.body.classList.toggle('searching', searching);

  document.querySelectorAll('.uni').forEach(u=>{
    const sn=u.dataset.name||'';
    const hay=(sn+' '+(nameMap[sn]||sn)).toLowerCase();
    const hit = searching && hay.includes(q);

    u.classList.toggle('hit', hit);

    if(hit) hits.add(sn);
  });

  document.querySelectorAll('.row').forEach(row=>{
    if(!searching){
      row.classList.remove('search-empty');
      return;
    }

    const hasHit = !!row.querySelector('.uni.hit');
    row.classList.toggle('search-empty', !hasHit);
  });

  document.querySelectorAll('td.day.exam').forEach(td=>{
    if(!searching){
      td.classList.remove('search-empty');
      return;
    }

    const hasHit = !!td.querySelector('.uni.hit');
    td.classList.toggle('search-empty', !hasHit);
  });

  document.querySelectorAll('#agenda .ag-card').forEach(card=>{
    if(card.classList.contains('su')){
      card.classList.remove('search-empty');
      return;
    }

    if(!searching){
      card.classList.remove('search-empty');
      return;
    }

    const hasHit = !!card.querySelector('.uni.hit');
    card.classList.toggle('search-empty', !hasHit);
  });

  qcountEl.textContent = !searching 
    ? '' 
    : (hits.size ? hits.size+'곳 일치' : '일치하는 대학 없음');
}
qEl.addEventListener('input',runSearch);
document.getElementById('qx').addEventListener('click',()=>{ qEl.value=''; runSearch(); qEl.focus(); });

