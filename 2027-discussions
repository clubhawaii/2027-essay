/* ---- desktop grid ---- */
function buildMonth(year,m){
  const first=new Date(year,m-1,1).getDay(), days=new Date(year,m,0).getDate();
  let html = `
<div class="month">
<h2>
<button onclick="prevMonth()" ${m===10 ? "disabled" : ""}>◀</button>

<span>${year}년 ${m}월</span>

<button onclick="nextMonth()" ${m===12 ? "disabled" : ""}>▶</button>
</h2>

<table class="cal">
<thead><tr>
`;
  DOW.forEach((d,i)=>html+=`<th class="${i===0?'sun':i===6?'sat':''}">${d}</th>`); html+=`</tr></thead><tbody><tr>`;
  for(let i=0;i<first;i++) html+=`<td class="empty"></td>`;
  for(let d=1;d<=days;d++){
    const dow=(first+d-1)%7; if(dow===0&&d!==1) html+=`</tr><tr>`;
    const e=exams[`${m}-${d}`], dc=dow===0?'sun':dow===6?'sat':'';
    if(e&&e.suneung) html+=`<td class="day suneung"><span class="dnum">${d}</span><div class="su-label">수능일</div><div class="su-sub">대학수학능력시험</div></td>`;
    else if(e){ let s=`<span class="dnum">${d}</span>`; if(e.in)s+=rowHTML('inmun','인문',e.in); if(e.ja)s+=rowHTML('jayeon','자연',e.ja); if(e.md)s+=rowHTML('med','메디컬',e.md); if(CMPDATA[`${m}-${d}`])s+=`<button class="cmpbtn" onclick="openCompare('${m}-${d}')">⚖ 동시비교</button>`; html+=`<td class="day exam ${dc}">${s}</td>`; }
    else html+=`<td class="day ${dc}"><span class="dnum">${d}</span></td>`;
  }
  const last=(first+days-1)%7; for(let i=last+1;i<7;i++) html+=`<td class="empty"></td>`;
  html+=`</tr></tbody></table></div>`; return html;
}
