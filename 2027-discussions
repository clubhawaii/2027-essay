function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
/* ===== 동시 비교 (같은 날 교시 병행 응시) ===== */
const CMPDATA=(function(){
  function pt(t){const m=[...t.matchAll(/(\d{1,2}):(\d{2})/g)]; if(!m.length)return {s:null,e:null};
    const s=+m[0][1]*60+ +m[0][2]; const e=m[1]?(+m[1][1]*60+ +m[1][2]):null; return {s,e};}
  const by={};
  for(const[name,v] of Object.entries(SES)){ if(v.ref) continue;
    const disp=name==="한국외국어대"?"한국외대(서울·글로벌)":name;
    for(const r of v.rows){const tm=pt(r.t); const dm=r.d.match(/(\d+)\/(\d+)/); const key=(+dm[1])+"-"+(+dm[2]);
      (by[key]=by[key]||[]).push({uni:disp,key:name,label:r.t,ty:r.ty,units:r.u,s:tm.s,e:tm.e});}
  }
  for(const k of Object.keys(by)){ if(new Set(by[k].map(x=>x.uni)).size<2) delete by[k]; }
  return by;
})();
function openCompare(key){
  const searchQ = (document.getElementById('q')?.value || '').trim().toLowerCase();
  function matchSearchUni(uni){
    if(!searchQ) return true;
    return uni.toLowerCase().includes(searchQ);
  }
  const items=CMPDATA[key]; if(!items) return;
  const dispKey={}; items.forEach(x=>dispKey[x.uni]=x.key);
  const T0=480,T1=1260,SPAN=T1-T0,EST=100;
  const fmt=x=>x==null?null:String(Math.floor(x/60)).padStart(2,'0')+':'+String(x%60).padStart(2,'0');
  const tyc=ty=>/메디컬/.test(ty)?'cmd':/자연|수리|공학|ICT/.test(ty)?'cja':/인문|언어|상경|사회/.test(ty)?'cin':'cetc';
  const ov=(a,b)=>{const ae=a.e!=null?a.e:(a.s!=null?a.s+EST:null),be=b.e!=null?b.e:(b.s!=null?b.s+EST:null); if(a.s==null||b.s==null)return null; return a.s<be&&b.s<ae;};
  const byU={}; items.forEach(x=>(byU[x.uni]=byU[x.uni]||[]).push(x));
  let ticks='<div class="ctl-ticks"><div class="cln"></div><div class="ctrack">';
  for(let t=T0;t<=T1;t+=60){const l=(t-T0)/SPAN*100; ticks+='<span class="ctick" style="left:'+l.toFixed(2)+'%">'+String(t/60).padStart(2,'0')+'</span>';}
  ticks+='</div></div>';
  const lanes=Object.entries(byU).map(([u,arr])=>{
    const blk=arr.map(x=>{
      if(x.s==null) return '<div class="cblk cetc" style="left:2px;width:88px" title="'+x.label+' · '+x.units+'"><b>'+x.label+'</b><span class="cbt">미정</span></div>';
      const e=x.e!=null?x.e:x.s+EST, l=(x.s-T0)/SPAN*100, w=Math.max((e-x.s)/SPAN*100,5), est=x.e==null?' cest':'';
      const lab=(x.label.replace(/\s*\d{1,2}:\d{2}.*/,'')||x.ty);
      return '<div class="cblk '+tyc(x.ty)+est+'" style="left:'+l.toFixed(2)+'%;width:'+w.toFixed(2)+'%" title="'+x.label+' · '+x.ty+' · '+x.units+'"><b>'+lab+'</b><span class="cbt">'+fmt(x.s)+(x.e?'~'+fmt(x.e):'~?')+'</span></div>';
    }).join('');
    return '<div class="clane"><div class="cln cmp-uni" data-uni="'+esc(dispKey[u]||u)+'" role="button" tabindex="0">'+u+'</div><div class="ctrack">'+blk+'</div></div>';
  }).join('');
  const us=Object.keys(byU),oks=[],unk=[];
  for(let i=0;i<us.length;i++)for(let j=i+1;j<us.length;j++){
    const A=byU[us[i]],B=byU[us[j]]; let combo=null,unknown=false;
    for(const a of A)for(const b of B){const o=ov(a,b); if(o===false){const f=a.s<=b.s?[a,b]:[b,a]; if(!combo||f[0].s<combo[0].s)combo=f;} if(o===null)unknown=true;}
    const pairHasSearch =
      !searchQ || matchSearchUni(us[i]) || matchSearchUni(us[j]);
    if(pairHasSearch){
      if(combo) oks.push({a:us[i],b:us[j],c:combo}); 
      else if(unknown) unk.push(us[i]+'↔'+us[j]);
    }
  }
  let par='<div class="cpar"><div class="cparh">✅ 같은 날 같이 응시할 수 있는 조합</div>';
  if(oks.length) par+='<ul>'+oks.map(p=>'<li><b><span class="cmp-uni" data-uni="'+esc(dispKey[p.a]||p.a)+'">'+p.a+'</span> + <span class="cmp-uni" data-uni="'+esc(dispKey[p.b]||p.b)+'">'+p.b+'</span></b> <span class="cex">'+p.c[0].uni+' '+fmt(p.c[0].s)+(p.c[0].e?'~'+fmt(p.c[0].e):'')+' 본 뒤 → '+p.c[1].uni+' '+fmt(p.c[1].s)+(p.c[1].e?'~'+fmt(p.c[1].e):'')+' 응시 가능</span></li>').join('')+'</ul>';
  else par+='<p class="cnone">이 날은 시험 시간이 서로 겹쳐서, 두 학교를 같은 날 모두 응시하기는 어려워요.</p>';
  if(unk.length) par+='<p class="cwarn">⚠ 아직 시험 시간이 공개되지 않아 판단할 수 없는 조합: '+unk.join(', ')+'</p>';
  par+='</div>';
  const lab=key.replace('-','/');
  let html='<div class="mhead"><h3>'+lab+' · 같은 날 둘 다 볼 수 있나요?</h3><button class="x" onclick="closeUni()">✕</button></div><div class="mbody">';
  html+='<p class="cmpdesc">이 날 논술이 있는 학교들의 시험 시간을 비교했어요. 시간이 겹치지 않으면 하루에 두 학교를 모두 응시할 수 있습니다. 아래 ✅ 조합을 확인하세요.</p>';
  html+=par;
  html+='<div class="cmpgraph-h">🕘 시험 시간표 자세히 보기</div>';
  html+='<p class="cmpnote">가로 막대 = 각 학교 시험 시간 · 빗금 = 종료시간 추정 · 회색 = 시험시간 미정</p>';
  html+='<div class="ctl">'+ticks+lanes+'</div></div>';
  const modal=document.getElementById('modal'); modal.innerHTML=html; modal.classList.add('wide'); document.getElementById('ov').classList.add('on');
}
function rowHTML(cls,tag,list){
  return `<span class="row ${cls}">
  <span class="tag">${tag}</span>` +
  list.map(n=>{
    const f=nameMap[n]||n;
    const mk=SES[f]
        ? ' <span class="sesmk" title="교시·시간 분리">⏱</span>'
        : '';

    return `<span class="uniwrap">
        <span class="uni" data-name="${esc(n)}">${n}${mk}</span>
    </span>`;
  }).join("") +
  `</span>`;
}
