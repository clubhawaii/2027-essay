<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css">
<style>
  :root{
    --pink:#FF5F9F;
    --ink:#191919; --sub:#9A9A9A; --line:#EDEDED; --bd:#E6E6E6; --muted-2:#BBBBBB;
    --sat:#1d4ed8; --sun:#dc2626;
    --inmun-bg:#f5f8ff; --inmun-bd:#d6e2f5; --inmun-tx:#3a5a8c; --inmun-tag:#3a5a8c;
    --jayeon-bg:#f3faf6; --jayeon-bd:#cfe7d9; --jayeon-tx:#3a7a63; --jayeon-tag:#3a7a63;
    --med-bg:#f9f6fd; --med-bd:#e4d8f0; --med-tx:#6a5a86; --med-tag:#6a5a86;
    --sb-bg:#ffffff; --sb-bd:#E6E6E6; --sb-tx:#191919; --sb-tag:#191919;
    --exam:#ffffff; --suneung:#191919; --paper:#ffffff; --board:#ffffff;
  }
  *{box-sizing:border-box;}
  body{margin:0; background:#fff; color:var(--ink);
    font-family:"Pretendard","Apple SD Gothic Neo","Malgun Gothic","Noto Sans KR",system-ui,sans-serif;
    font-variant-numeric:tabular-nums;
    -webkit-font-smoothing:antialiased; padding:24px 20px 72px;}
  .wrap{max-width:1240px; margin:0 auto;}
  .brandbar{display:flex; align-items:center; padding:14px 0; border-bottom:1px solid var(--line); margin-bottom:18px;}
  .brandlogo{height:32px; width:auto; display:block;}
  header.top .eyebrow{font-size:13px; letter-spacing:.18em; color:var(--pink); font-weight:700;}
  header.top h1{font-size:clamp(24px,5vw,32px); margin:7px 0 5px; letter-spacing:-.01em;}
  header.top p{margin:0; color:var(--sub); font-size:15px;}
  .legend{display:flex; gap:14px; flex-wrap:wrap; margin-top:16px; font-size:14px;}
  .legend span{display:inline-flex; align-items:center; gap:6px; color:var(--sub);}
  .dot{width:13px; height:13px; border-radius:3px; display:inline-block;}
  .d-in{background:var(--inmun-tag);} .d-ja{background:var(--jayeon-tag);}
  .d-md{background:var(--med-tag);} .d-su{background:var(--suneung);}
  .hint{margin-top:10px; font-size:13px; color:var(--sub);}

  /* 상단 고정 툴바 */
  .toolbar{position:sticky; top:0; z-index:40; background:#fff; border-bottom:1px solid var(--line); padding:11px 0; margin:14px 0 10px;}
  .tb-row{display:flex; gap:10px; align-items:center; flex-wrap:wrap;}
  .tb-sub{margin-top:9px;}
  .search{display:flex; gap:8px; align-items:center; flex:1; min-width:200px; border:1.5px solid var(--line); border-radius:12px; padding:7px 8px 7px 14px;}
  .search input{flex:1; border:none; outline:none; font-size:16px; font-family:inherit; color:var(--ink); background:transparent;}
  .search input::placeholder{color:var(--muted-2);}
  .search .qx{border:none; background:var(--line); color:var(--ink); width:30px; height:30px; border-radius:8px; font-size:13px; cursor:pointer; flex:0 0 auto; display:none;}
  body.searching .search .qx{display:block;}
  .chips{display:flex; gap:8px; flex-wrap:wrap;}
  .chip{font-size:14px; font-weight:600; padding:8px 15px; border-radius:10px; border:1.5px solid var(--line); background:#fff; color:var(--sub); cursor:pointer;}
  .chip.on{background:var(--pink); border-color:var(--pink); color:#fff;}
  .qcount{font-size:12.5px; color:var(--sub); margin-left:auto; align-self:center;}

  /* 달력 / 리스트 토글 */
  .viewtoggle{display:flex; gap:8px;}
  .vt{font-size:14px; font-weight:600; padding:9px 16px; border-radius:10px; border:1.5px solid var(--line); background:#fff; color:var(--sub); cursor:pointer;}
  .vt.on{background:var(--ink); border-color:var(--ink); color:#fff;}

  /* 카테고리 필터 (행 숨김) */
  body.flt-in .row.jayeon, body.flt-in .row.med{display:none;}
  body.flt-ja .row.inmun, body.flt-ja .row.med{display:none;}
  body.flt-md .row.inmun, body.flt-md .row.jayeon{display:none;}

  /* 검색 하이라이트 / 디밍 */
/* 검색 시 해당 대학이 있는 날짜만 표시 */
  body.searching .uni:not(.hit){
    display:none;
  }

  body.searching .row.search-empty{
    display:none;
  }

  body.searching td.day.exam.search-empty .row,
  body.searching td.day.exam.search-empty .cmpbtn{
    display:none;
  }

  body.searching #agenda .ag-card.search-empty{
    display:none;
  }

  body.searching .uni.hit{
    background:rgba(255,95,159,.18);
    outline:1px solid var(--pink);
    border-radius:3px;
    border-bottom-color:transparent;
  }

  /* 하단 홍보(CTA) */
  .promo{border:1px solid var(--line); border-radius:14px; padding:22px 20px; text-align:center; margin:26px 0 14px;}
  .promo-h{font-size:18px; font-weight:700; color:var(--ink);}
  .promo-h .pk{color:var(--pink);}
  .promo-p{font-size:15px; color:var(--sub); margin-top:6px;}
  .promo-btns{display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:16px;}
  .pbtn{display:inline-flex; align-items:center; gap:7px; font-size:15px; font-weight:700; padding:12px 20px; border-radius:10px; border:1.5px solid var(--line); background:#fff; color:var(--ink); text-decoration:none;}
  .pbtn .ic{font-size:18px;}
  .pbtn.primary{background:var(--ink); border-color:var(--ink); color:#fff;}
  .promo-pw{margin-top:14px; font-size:14px; color:var(--sub);}
  .promo-pw b{color:var(--ink); font-weight:700;}

  .month{background:var(--paper); border:1px solid var(--line); border-radius:14px; padding:18px 16px 20px; margin-bottom:22px;}

  table.cal{width:100%; border-collapse:separate; border-spacing:7px; table-layout:fixed;}
  table.cal th{font-size:14px; font-weight:700; color:var(--sub); padding:4px 0 8px; text-align:left; padding-left:4px;}
  th.sat{color:var(--sat);} th.sun{color:var(--sun);}
  td.day{vertical-align:top; min-height:120px; border:1px solid var(--line); border-radius:9px; padding:9px 10px; background:#fff;}
  td.empty{background:transparent; border:1px dashed #F4F4F4;}
  td.exam{background:var(--exam); border-color:var(--line);}
  td.suneung{background:var(--suneung); border-color:var(--suneung);}
  .dnum{font-size:16px; font-weight:800; line-height:1; margin-bottom:7px; display:block;}
  td.sat .dnum{color:var(--sat);} td.sun .dnum{color:var(--sun);}

  .row{display:block; border-radius:6px; padding:5px 7px; margin-bottom:5px; font-size:13px; line-height:1.45;}
  .row .tag{display:inline-block; font-weight:700; font-size:11px; margin-right:5px; padding:1px 5px; border-radius:4px; vertical-align:1px; background:#fff; border:1px solid currentColor;}
  .row.inmun{background:var(--inmun-bg); border:1px solid var(--inmun-bd); color:var(--inmun-tx);} .row.inmun .tag{color:var(--inmun-tag);}
  .row.jayeon{background:var(--jayeon-bg); border:1px solid var(--jayeon-bd); color:var(--jayeon-tx);} .row.jayeon .tag{color:var(--jayeon-tag);}
  .row.med{background:var(--med-bg); border:1px solid var(--med-bd); color:var(--med-tx);} .row.med .tag{color:var(--med-tag);}
  .uni{cursor:pointer; border-bottom:1px dotted currentColor;}
  .uni:hover{background:rgba(0,0,0,.06); border-radius:3px;}
  .uni:active{background:rgba(255,95,159,.18); border-radius:4px;}
  .uni,.cmpbtn,.chip,.vt,.pbtn,.utab{-webkit-tap-highlight-color:transparent;}
  .cmpbtn:active{background:var(--ink); color:#fff; border-color:var(--ink);}
  .suneung td, td.suneung .dnum{color:#fff;}
  .su-label{color:#fff; font-weight:800; font-size:16px; margin-top:5px;}
  .su-sub{color:#cbd2e0; font-size:12.5px; margin-top:3px;}
  footer{color:var(--sub); font-size:11.5px; text-align:center; margin-top:6px;}
  footer .credit{margin-top:14px; padding-top:12px; border-top:1px solid var(--line); color:var(--ink); font-size:12.5px; font-weight:600;}
  footer .copy{margin-top:5px; color:var(--muted-2); font-size:11.5px; line-height:1.6;}

  /* 달력 / 리스트 표시 전환 */
  .gridview,.agenda{display:none;}
  body.view-cal .gridview{display:block;}
  body.view-list .agenda{display:block;}

  /* agenda (리스트 뷰) */
  .agenda{max-width:880px; margin:0 auto;}
  .ag-month{font-size:19px; font-weight:800; color:var(--ink); margin:20px 2px 9px;}
  .ag-card{background:var(--paper); border:1px solid var(--line); border-radius:12px; padding:14px 16px; margin-bottom:11px;}
  .ag-card.su{background:var(--suneung); border-color:var(--suneung);}
  .ag-date{font-weight:800; font-size:16px; margin-bottom:8px;}
  .ag-date.sat{color:var(--sat);} .ag-date.sun{color:var(--sun);}
  .ag-card.su .ag-date{color:#fff;} .ag-su-sub{color:#cbd2e0; font-size:13px;}

  /* modal */
  .overlay{position:fixed; inset:0; background:rgba(25,25,25,.38); backdrop-filter:blur(2px); display:none; align-items:center; justify-content:center; padding:16px; z-index:50;}
  .overlay.on{display:flex;}
  @keyframes modalIn{from{opacity:0; transform:translateY(8px) scale(.99);} to{opacity:1; transform:none;}}
  .modal{background:#fff; border-radius:20px; max-width:560px; width:100%; max-height:88vh; overflow:auto; border:1px solid #F1F1F1; box-shadow:0 12px 40px rgba(20,20,30,.12);}
  .overlay.on .modal{animation:modalIn .18s ease;}
  .modal .mhead{position:sticky; top:0; background:#fff; padding:18px 22px 12px; border-bottom:1px solid #F4F4F4; display:flex; align-items:flex-start; justify-content:space-between;}
  .modal .mhead h3{margin:0; font-size:21px;}
  .modal .mhead .x{cursor:pointer; border:none; background:#F4F4F4; width:33px; height:33px; border-radius:10px; font-size:16px; color:var(--ink); flex:0 0 auto; transition:background .15s ease;}
  .modal .mhead .x:hover{background:var(--bd);}
  .modal .mbody{padding:16px 22px 24px;}
  .utabs{display:flex; gap:8px; margin:0 0 16px;}
  .utab{font-size:14px; font-weight:600; padding:8px 16px; border-radius:10px; border:1.5px solid var(--line); background:#fff; color:var(--sub); cursor:pointer;}
  .utab.on{background:var(--ink); border-color:var(--ink); color:#fff;}
  .cmp-uni{cursor:pointer; border-bottom:1px dotted currentColor;}
  .cmp-uni:hover{color:var(--pink);}
  .cln.cmp-uni{border-bottom:none; text-decoration:underline; text-decoration-style:dotted; text-underline-offset:2px;}
  .cln.cmp-uni:hover{color:var(--pink);}
  .kv{display:flex; gap:10px; font-size:14.5px; padding:7px 0; border-bottom:1px dashed #EFEFEF;}
  .kv .k{flex:0 0 86px; color:var(--sub); font-weight:700;}
  .kv-note{color:var(--sub); font-size:12.5px;}
  .sect{margin-top:14px;}
  .sect h4{margin:0 0 7px; font-size:14px;}
  .sect h4.sb{color:var(--sb-tx);} .sect h4.in{color:var(--inmun-tx);} .sect h4.ja{color:var(--jayeon-tx);} .sect h4.md{color:var(--med-tx);}
  .box{border-radius:12px; padding:11px 13px; font-size:14px; line-height:1.5;}
  .box.ses{overflow:hidden;}
  .box.sb{background:var(--sb-bg); border:1px solid var(--sb-bd);}
  .box.in{background:var(--inmun-bg); border:1px solid var(--inmun-bd);}
  .box.ja{background:var(--jayeon-bg); border:1px solid var(--jayeon-bd);}
  .box.md{background:var(--med-bg); border:1px solid var(--med-bd);}
  .box .base{font-weight:700;} .box ul{margin:6px 0 0; padding-left:18px;} .box li{margin:2px 0;}
  .sbline{display:flex; gap:8px; padding:4px 0; font-size:14px;}
  .sbline .sk{flex:0 0 80px; color:var(--sb-tx); font-weight:700;}
  .sbnote{margin-top:5px; font-size:13px; color:var(--sub);}
  .box.in .sk{color:var(--inmun-tx);}
  .box.ja .sk{color:var(--jayeon-tx);}
  .qline{font-size:13px; line-height:1.55; margin:2px 0;}

  @media (max-width:760px){
    .gridview{display:none!important;} .agenda{display:block!important;}
    .viewtoggle{display:none;}
    .toolbar{padding:9px 0;}
    .search{flex-basis:100%;}
    body{padding:24px 16px 72px;}

    /* 리스트 카드 가독성 */
    .ag-month{font-size:17px; margin:22px 2px 9px; padding-top:6px; border-top:1px solid var(--line);}
    .ag-month:first-child{border-top:none; padding-top:0; margin-top:6px;}
    .ag-card{padding:16px 16px; margin-bottom:12px; border-radius:14px;}
    .ag-date{font-size:17px; margin-bottom:10px;}
    .row{font-size:14px; line-height:1.7; padding:6px 8px;}
    .row .tag{font-size:11.5px; margin-right:6px;}

    /* 터치 타깃 — 손가락으로 누르기 쉽게 */
    .uni{display:inline-block; padding:3px 4px; margin:1px 0;}
    .cmpbtn{font-size:12px; padding:7px 12px; margin-top:8px;}

    /* 하단 홍보·저작권 정리 */
    .promo{padding:18px 16px;}
    .promo-h{font-size:16.5px;}
    .promo-p{font-size:14px;}
    .promo-btns{flex-direction:column; gap:9px;}
    .pbtn{width:100%; justify-content:center; padding:13px 18px;}
    .promo-pw{margin-top:13px; font-size:13.5px;}
    footer .credit{margin-top:16px;}
    footer .copy{line-height:1.7;}

    .modal{max-width:none; border-radius:18px 18px 0 0; align-self:flex-end; max-height:90vh;}
    .overlay{align-items:flex-end; padding:0;}
  }
  @media print{ body{background:#fff;} .gridview{display:block!important;} .month{break-inside:avoid; box-shadow:none;} .hint,.overlay,.agenda,.viewtoggle,.toolbar,.promo{display:none;} }

