function prevMonth(){
  if(currentMonth > 10){
    currentMonth--;
    renderCalendar();
    if(typeof runSearch === "function"){
        runSearch();
    }
  }
}
function nextMonth(){
  if(currentMonth < 12){
    currentMonth++;
    renderCalendar();
    if(typeof runSearch === "function"){
        runSearch();
    }
  }
}

