    let s=""; if(e.in)s+=rowHTML('inmun','인문',e.in); if(e.ja)s+=rowHTML('jayeon','자연',e.ja); if(e.md)s+=rowHTML('med','메디컬',e.md); if(CMPDATA[key])s+=`<button class="cmpbtn" onclick="openCompare('${key}')">⚖ 동시비교</button>`;
