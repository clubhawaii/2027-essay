function tyHas(ty,c){
  if(c==='ja') return /자연|수리|공학|ICT|이학/.test(ty);
  if(c==='in') return /인문|언어|상경|사회|경상|예술|자유전공/.test(ty);
  return true; // md 등은 전체
}
function sesBox(key,cat){
  let s=SES[key]; if(!s) return "";
  if(s.ref) s=SES[s.ref];
  if(!s||!s.rows) return "";
  let list=s.rows;
  if(cat==='in'||cat==='ja'){ const f=list.filter(r=>tyHas(r.ty,cat)); if(!f.length) return ""; list=f; }
  const rows=list.map(r=>`<tr><td class="sd">${r.d}</td><td class="st">${r.t}</td><td class="sy">${r.ty}</td><td class="su">${r.u}</td></tr>`).join("");
  return `<div class="sect"><h4 class="ses">교시·시험시간별 모집단위${s.note?` <span style="font-weight:600;font-size:11px;color:var(--sub)">· ${s.note}</span>`:""}</h4><div class="box ses"><table class="sestbl"><thead><tr><th>일자</th><th>교시·시간</th><th>유형</th><th>모집단위</th></tr></thead><tbody>${rows}</tbody></table></div></div>`;
}
function choijeBox(cls,label,c){ if(!c) return ""; let in_=`<div class="base">${c.b}</div>`; if(c.u&&c.u.length) in_+=`<ul>`+c.u.map(x=>`<li>${x}</li>`).join("")+`</ul>`; return `<div class="sect"><h4 class="${cls}">${label}</h4><div class="box ${cls}">${in_}</div></div>`; }
function sbBox(d,cat){
  let inner="";
  inner+=`<div class="sbline"><div class="sk">반영비율</div><div>${d.rb}</div></div>`;
  if(typeof d.sb==="string"){ inner+=`<div class="sbline"><div class="sk">학생부</div><div>${d.sb}</div></div>`; }
  else{ const p=[]; if(d.sb.c)p.push(d.sb.c);
    if(d.sb.i && cat!=='ja')p.push("인문 "+d.sb.i);
    if(d.sb.j && cat!=='in')p.push("자연 "+d.sb.j);
    inner+=`<div class="sbline"><div class="sk">학생부</div><div>${p.join(" · ")}${d.sb.n?`<div class="sbnote">▸ ${d.sb.n}</div>`:""}</div></div>`; }
  inner+=`<div class="sbline"><div class="sk">학년별</div><div>${d.gb}</div></div>`;
  return `<div class="sect"><h4 class="sb">학생부 반영</h4><div class="box sb">${inner}</div></div>`;
}
function inmunBox(key){
  const x=IN[key]; if(!x) return "";
  let inner=`<div class="sbline"><div class="sk">출제유형</div><div>${x.ot}</div></div>`;
  inner+=`<div class="sbline"><div class="sk">시간</div><div>${x.tm}분</div></div>`;
  if(x.q) inner+=`<div class="sbline"><div class="sk">문항별</div><div>`+x.q.map(s=>`<div class="qline">· ${s}</div>`).join("")+`</div></div>`;
  else inner+=`<div class="sbline"><div class="sk">문항별</div><div>전년도 자료 없음</div></div>`;
  return `<div class="sect"><h4 class="in">인문논술 출제정보 <span style="font-weight:600;font-size:11px;color:var(--sub)">· 문항별=2026학년도</span></h4><div class="box in">${inner}</div></div>`;
}
function jayeonBox(key){
  const x=JA[key]; if(!x) return "";
  let inner=`<div class="sbline"><div class="sk">출제유형</div><div>${x.ot}</div></div>`;
  inner+=`<div class="sbline"><div class="sk">시간</div><div>${x.tm}분</div></div>`;
  if(x.q) inner+=`<div class="sbline"><div class="sk">문항별</div><div>`+x.q.map(s=>`<div class="qline">· ${s}</div>`).join("")+`</div></div>`;
  else inner+=`<div class="sbline"><div class="sk">문항별</div><div>전년도 자료 없음</div></div>`;
  return `<div class="sect"><h4 class="ja">자연논술 출제정보 <span style="font-weight:600;font-size:11px;color:var(--sub)">· 문항별=2026학년도</span></h4><div class="box ja">${inner}</div></div>`;
}
function medBox(d){
  return `<div class="sect"><h4 class="md">메디컬 (의·치·한·약·수의·간호)</h4><div class="box md"><ul>`+d.med.map(x=>`<li>${x}</li>`).join("")+`</ul></div></div>`;
}
function uniBody(key,d,cat){
  let h=`<div class="kv"><div class="k">모집인원</div><div>${d.r}명 <span class="kv-note">· 계열 구분 없는 논술 전체 인원</span></div></div>`;
  if(cat==='in')      h+=`<div class="kv"><div class="k">논술일</div><div>${d.i||"—"}</div></div>`;
  else if(cat==='ja') h+=`<div class="kv"><div class="k">논술일</div><div>${d.j||"—"}</div></div>`;
  else                h+=`<div class="kv"><div class="k">논술일</div><div>인문 ${d.i||"—"} / 자연 ${d.j||"—"}</div></div>`;
  h+=sesBox(key,cat);
  if(cat==='in') h+=inmunBox(key);
  else if(cat==='ja') h+=jayeonBox(key);
  h+=sbBox(d,cat);
  if(cat==='in') h+=choijeBox('in','수능최저 — 인문',d.ci);
  else if(cat==='ja') h+=choijeBox('ja','수능최저 — 자연',d.cj);
  else if(cat==='md' && d.med&&d.med.length) h+=medBox(d);
  return h;
}
function openUni(name,cat){
  const key=nameMap[name]||name, d=U[key]; if(!d) return;
  const avail=[];
  if(d.ci) avail.push('in');
  if(d.cj) avail.push('ja');
  if(d.med&&d.med.length) avail.push('md');
  if(!avail.length) avail.push('in');
  let active = avail.includes(cat)? cat : avail[0];
  const LAB={in:'인문',ja:'자연',md:'메디컬'};
  const _m=document.getElementById('modal');
  function render(){
    const tabs = avail.length>1
      ? `<div class="utabs">`+avail.map(c=>`<button class="utab ${c===active?'on':''}" data-c="${c}">${LAB[c]}</button>`).join('')+`</div>`
      : '';
    _m.classList.remove('wide');
    _m.innerHTML=`<div class="mhead"><h3>${key}</h3><button class="x" onclick="closeUni()">✕</button></div><div class="mbody">${tabs}${uniBody(key,d,active)}</div>`;
    _m.querySelectorAll('.utab').forEach(b=>b.addEventListener('click',()=>{ active=b.dataset.c; render(); }));
  }
  render();
  document.getElementById('ov').classList.add('on');
}
function closeUni(){ document.getElementById('ov').classList.remove('on'); }
document.body.addEventListener('click',ev=>{
  const cu=ev.target.closest('.cmp-uni'); if(cu){ openUni(cu.dataset.uni); return; }
  const t=ev.target.closest('.uni'); if(!t) return;
  const row=t.closest('.row');
  const cat = row && row.classList.contains('inmun') ? 'in'
            : row && row.classList.contains('jayeon') ? 'ja'
            : row && row.classList.contains('med') ? 'md' : null;
  openUni(t.dataset.name, cat);
});
document.getElementById('ov').addEventListener('click',ev=>{ if(ev.target.id==='ov') closeUni(); });
document.addEventListener('keydown',ev=>{ if(ev.key==='Escape') closeUni(); });
</script>
</body>
</html>
